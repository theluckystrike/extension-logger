{
  "name": "extension-logger",
  "version": "0.1.0",
  "description": "Structured logging for Chrome extensions — log levels, context tags, storage persistence, export, and performance timing. Zero dependencies.",
  "author": "Zovo <hello@zovo.one>",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "chrome-extension",
    "logger",
    "logging",
    "debug",
    "console",
    "log-levels",
    "structured-logging",
    "manifest-v3",
    "browser-extension",
    "devtools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theluckystrike/extension-logger.git"
  },
  "homepage": "https://github.com/theluckystrike/extension-logger",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/jest": "^29.5.14",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  }
}
